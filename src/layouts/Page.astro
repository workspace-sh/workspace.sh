---
import Base from './Base.astro';

interface Frontmatter {
  title: string;
  description?: string;
}

interface Props {
  frontmatter?: Frontmatter;
  title?: string;
  description?: string;
}

// Markdown files with `layout: ./Page.astro` pass frontmatter under
// Astro.props.frontmatter. .astro callers can pass title/description
// directly. Support both.
const { frontmatter, title, description } = Astro.props;
const resolvedTitle = title ?? frontmatter?.title ?? '';
const resolvedDescription = description ?? frontmatter?.description;
---
<Base title={resolvedTitle} description={resolvedDescription}>
  <article>
    <slot />
  </article>
</Base>
