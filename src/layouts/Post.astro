---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  type?: 'note' | 'image' | 'video';
}

const { title, date, description, type = 'note' } = Astro.props;
const iso = date.toISOString().slice(0, 10);
// DD.MM.YYYY — matches the ledger.
const [_y, _m, _d] = iso.split('-');
const formatted = `${_d}.${_m}.${_y}`;
const objectLabel = { note: 'Note', image: 'Image', video: 'Video' }[type];
---
<Base title={`${title} — workspace.sh`} description={description}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={iso}>{formatted}</time>
        <span>{objectLabel}</span>
      </div>
    </header>
    <div class="post-body">
      <slot />
    </div>
  </article>
  <nav class="nav">
    <a href="/devlog/">← Development Log</a>
    <a href="/">Home</a>
  </nav>
</Base>
