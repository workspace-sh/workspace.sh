---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('devlog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatDate = (d: Date) =>
  d.toISOString().slice(0, 10).replace(/-/g, '.');
---
<Base title="Devlog — workspace.sh" description="Notes, updates, work in progress.">
  <h1 class="wordmark">Devlog</h1>

  {posts.length === 0 ? (
    <p class="empty">No entries yet.</p>
  ) : (
    <div class="ledger-wrap">
      <table class="ledger">
        <thead>
          <tr>
            <th class="col-date">Date</th>
            <th class="col-type">Type</th>
            <th class="col-subject">Subject</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post) => (
            <tr>
              <td class="col-date">{formatDate(post.data.date)}</td>
              <td class="col-type">Devlog</td>
              <td class="col-subject">
                <a href={`/devlog/${post.id}/`}>{post.data.title}</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <nav class="nav">
    <a href="/">← Home</a>
  </nav>
</Base>
