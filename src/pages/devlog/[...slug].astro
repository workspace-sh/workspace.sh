---
import { getCollection, render } from 'astro:content';
import Post from '../../layouts/Post.astro';

export async function getStaticPaths() {
  const posts = await getCollection('devlog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

// Normalize a YouTube ID / URL into just the ID.
function youtubeId(input: string | undefined): string | null {
  if (!input) return null;
  const m = input.match(
    /(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/,
  );
  if (m) return m[1];
  if (/^[A-Za-z0-9_-]{11}$/.test(input)) return input;
  return null;
}

const ytId = youtubeId(d.video);

// Collect images from either the single `image` field or the `images` array.
const gallery = [
  ...(d.image ? [{ src: d.image, alt: d.imageAlt }] : []),
  ...(d.images ?? []),
];
---
<Post title={d.title} date={d.date} description={d.description} type={d.type}>
  {d.videoSrc && (
    <figure class="post-media">
      <video
        controls
        preload="metadata"
        playsinline
        poster={d.videoPoster}
        src={d.videoSrc}
      ></video>
    </figure>
  )}

  {ytId && (
    <figure class="post-media">
      <div class="video-embed">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${ytId}`}
          title={d.title}
          loading="lazy"
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </figure>
  )}

  {gallery.length > 0 && (
    <div class={`post-gallery${gallery.length > 1 ? ' is-grid' : ''}${d.transparentMedia ? ' is-bare' : ''}`}>
      {gallery.map((img) => (
        <figure class="post-media">
          <img src={img.src} alt={img.alt ?? ''} loading="lazy" decoding="async" />
        </figure>
      ))}
    </div>
  )}

  <Content />
</Post>
