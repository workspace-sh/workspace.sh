---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;
const iso = date.toISOString().slice(0, 10);
const formatted = iso.replace(/-/g, '.');
---
<Base title={`${title} — workspace.sh`} description={description}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={iso}>{formatted}</time>
        <span>Devlog</span>
      </div>
    </header>
    <div class="post-body">
      <slot />
    </div>
  </article>
  <nav class="nav">
    <a href="/devlog/">← Devlog</a>
    <a href="/">Home</a>
  </nav>
</Base>
