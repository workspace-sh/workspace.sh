---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('devlog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---
<Base title="Devlog" description="Notes, updates, and work in progress.">
  <article>
    <h1>Devlog</h1>
    {posts.length === 0 ? (
      <p>No posts yet.</p>
    ) : (
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/devlog/${post.id}/`}>{post.data.title}</a>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-GB', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </li>
        ))}
      </ul>
    )}
  </article>
</Base>
